# ── iCal feeds ──────────────────────────────────────────────────────────────
# Comma-separated iCal feed URLs (one per booking provider)
ICAL_URLS=https://feeds.booking.com/xxxx.ics,https://www.airbnb.com/calendar/ical/xxxx.ics
# Matching source identifiers (must align with ICAL_URLS order)
ICAL_SOURCES=ical_bookingcom,ical_airbnb
# Optional human-readable labels per feed (used in notifications)
ICAL_LABELS=Booking.com,Airbnb

# ── Sunclass management portal ──────────────────────────────────────────────
SUNCLASS_EMAIL=you@example.com
SUNCLASS_PASSWORD=secret
SUNCLASS_LOGIN_URL=https://mijn.sunclassdurbuy.com/login
SUNCLASS_URL=https://mijn.sunclassdurbuy.com/reservations
SCRAPER_TIMEOUT_MS=30000
# Optional property label (leave blank for single-property setups)
PROPERTY_LABEL=

# ── Notification channels ───────────────────────────────────────────────────
# Comma-separated: telegram, stdout
NOTIFIER_CHANNELS=telegram,stdout

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100123456789

# ── Matching behaviour ──────────────────────────────────────────────────────
# Reservations with check-in within this many days are CRITICAL:
# they are reported on every run (not just once) and formatted prominently.
# Discrepancies beyond this window are informational and reported only once.
CRITICAL_WINDOW_DAYS=30

# Airbnb blocks dates within its minimum pre-booking window, producing "0 days until
# arrival" noise. Skip any Airbnb iCal entry whose check-in is fewer than N days away.
AIRBNB_MIN_CHECKIN_DAYS=1

# Airbnb places a rolling 1-day phantom block at its 365-day max booking horizon.
# Skip 1-day Airbnb entries whose check-in is N or more days away.
AIRBNB_PHANTOM_HORIZON_DAYS=362

# Allow ±N days when fuzzy-matching dates across sources (0 = exact only)
DATE_TOLERANCE_DAYS=0
ICAL_FETCH_TIMEOUT_SECONDS=30
CANONICAL_TZ=Europe/Brussels

# ── Runtime / logging ───────────────────────────────────────────────────────
STATE_DB_PATH=data/state.db
LOG_FILE_PATH=data/sunclass.log
LOG_LEVEL=INFO

# ── Playwright debug (optional) ─────────────────────────────────────────────
# Set PLAYWRIGHT_HEADLESS=false to open a visible browser window (useful for debugging)
# Set PLAYWRIGHT_SLOWMO to slow down each browser action by N milliseconds
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOWMO=0
